{
  "manifest_version": 3,
  "name": "Vestiga Password Manager",
  "version": "1.0.0",
  "description": "Secure password manager extension for Vestiga.",
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/autofill-ui.css"],
      "js": [
        "content/formDetector.js",
        "content/autofillEngine.js",
        "content/autofillDropdown.js",
        "content/savePrompt.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/autofill-ui.css",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
